# Hugging Face token (required for gated models like Mistral-7B-Instruct-v0.2).
# Used on vast.ai / local_a100; left empty on macbook (no model loading).
HF_TOKEN=

# Optional. If empty, transformers / datasets use ~/.cache/huggingface.
# HF_HOME=

# vast.ai API key (used by `vastai` CLI). Optional.
VAST_API_KEY=

# Environment tag — install_*.sh sets this automatically.
# One of: macbook | vastai | local_a100
# COMPBLEND_ENV_TAG=

# Optional. Used only when pushing/cloning private branches via HTTPS.
GITHUB_PAT=
